{
  "design_name": "dma_axi64_testbench",
  "version": "1.0",
  "description": "Testbench for DMA AXI 64 \u2014 DUT connected to two AXI4 slave UVCs, one APB master UVC, and sideband signal generators. Based on blockify metadata from freecores/dma_axi.",
  "includes": [
    "blocks/dma_axi64.json",
    "blocks/axi4_slave_uvc.json",
    "blocks/apb_master_uvc.json",
    "blocks/sideband_signals.json"
  ],
  "parameters": {
    "DATA_WIDTH": 64,
    "ADDR_WIDTH": 32
  },
  "testbench": {
    "module_name": "tb_dma_axi64_top",
    "description": "DMA AXI 64 testbench with UVCs and sideband signals.",
    "global_signals": [
      {
        "name": "clk",
        "width": 1,
        "type": "reg",
        "render": {
          "face": "bottom",
          "color": "#00E676"
        }
      },
      {
        "name": "reset",
        "width": 1,
        "type": "reg",
        "render": {
          "face": "top",
          "color": "#FF5252"
        }
      }
    ]
  },
  "connection_types": {
    "axi4_bus": {
      "color": "#FFC107",
      "description": "AXI4 Bus"
    },
    "apb_bus": {
      "color": "#4CAF50",
      "description": "APB Bus"
    },
    "sideband": {
      "color": "#78909C",
      "description": "Sideband Signals"
    }
  },
  "modules": {},
  "instances": [
    {
      "instance_name": "u_dma_axi64",
      "module": "dma_axi64",
      "position": {
        "x": 0,
        "y": 0,
        "z": 0
      }
    },
    {
      "instance_name": "u_axi4_slave0",
      "module": "axi4_slave_uvc",
      "position": {
        "x": 15,
        "y": 3,
        "z": 0
      }
    },
    {
      "instance_name": "u_axi4_slave1",
      "module": "axi4_slave_uvc",
      "position": {
        "x": 15,
        "y": -3,
        "z": 0
      }
    },
    {
      "instance_name": "u_apb_master",
      "module": "apb_master_uvc",
      "position": {
        "x": -15,
        "y": 0,
        "z": 0
      }
    },
    {
      "instance_name": "u_sideband",
      "module": "sideband_signals",
      "position": {
        "x": 0,
        "y": 10,
        "z": 0
      }
    }
  ],
  "connections": [
    {
      "id": "clk_fanout",
      "type": "clock",
      "description": "System clock to all components",
      "from": {
        "instance": "tb_dma_axi64_top",
        "port": "clk"
      },
      "to": [
        {
          "instance": "u_dma_axi64",
          "port": "clk"
        },
        {
          "instance": "u_axi4_slave0",
          "port": "clk"
        },
        {
          "instance": "u_axi4_slave1",
          "port": "clk"
        },
        {
          "instance": "u_apb_master",
          "port": "pclk"
        }
      ]
    },
    {
      "id": "reset_fanout",
      "type": "reset",
      "description": "System reset to all components",
      "from": {
        "instance": "tb_dma_axi64_top",
        "port": "reset"
      },
      "to": [
        {
          "instance": "u_dma_axi64",
          "port": "reset"
        },
        {
          "instance": "u_axi4_slave0",
          "port": "rst_n"
        },
        {
          "instance": "u_axi4_slave1",
          "port": "rst_n"
        },
        {
          "instance": "u_apb_master",
          "port": "preset_n"
        }
      ]
    },
    {
      "id": "dma_to_axi_slave0",
      "type": "axi4_bus",
      "label": "AXI4 M0 \u2192 Slave UVC 0",
      "description": "DMA AXI master port 0 connected to AXI4 slave UVC 0",
      "from_instance": "u_dma_axi64",
      "to_instance": "u_axi4_slave0",
      "channel_signals": {
        "AW": [
          {
            "from_port": "AWID0",
            "wire": "axi0_awid",
            "to_port": "axi4_if"
          },
          {
            "from_port": "AWADDR0",
            "wire": "axi0_awaddr",
            "to_port": "axi4_if"
          },
          {
            "from_port": "AWLEN0",
            "wire": "axi0_awlen",
            "to_port": "axi4_if"
          },
          {
            "from_port": "AWSIZE0",
            "wire": "axi0_awsize",
            "to_port": "axi4_if"
          },
          {
            "from_port": "AWVALID0",
            "wire": "axi0_awvalid",
            "to_port": "axi4_if"
          }
        ],
        "W": [
          {
            "from_port": "WDATA0",
            "wire": "axi0_wdata",
            "to_port": "axi4_if"
          },
          {
            "from_port": "WSTRB0",
            "wire": "axi0_wstrb",
            "to_port": "axi4_if"
          },
          {
            "from_port": "WLAST0",
            "wire": "axi0_wlast",
            "to_port": "axi4_if"
          },
          {
            "from_port": "WVALID0",
            "wire": "axi0_wvalid",
            "to_port": "axi4_if"
          }
        ],
        "R": [
          {
            "from_port": "RDATA0",
            "wire": "axi0_rdata",
            "to_port": "axi4_if"
          },
          {
            "from_port": "RRESP0",
            "wire": "axi0_rresp",
            "to_port": "axi4_if"
          },
          {
            "from_port": "RLAST0",
            "wire": "axi0_rlast",
            "to_port": "axi4_if"
          },
          {
            "from_port": "RVALID0",
            "wire": "axi0_rvalid",
            "to_port": "axi4_if"
          }
        ]
      }
    },
    {
      "id": "dma_to_axi_slave1",
      "type": "axi4_bus",
      "label": "AXI4 M0 \u2192 Slave UVC 1",
      "description": "DMA AXI master port 0 connected to AXI4 slave UVC 1 (second slave)",
      "from_instance": "u_dma_axi64",
      "to_instance": "u_axi4_slave1",
      "channel_signals": {
        "AR": [
          {
            "from_port": "ARID0",
            "wire": "axi1_arid",
            "to_port": "axi4_if"
          },
          {
            "from_port": "ARADDR0",
            "wire": "axi1_araddr",
            "to_port": "axi4_if"
          },
          {
            "from_port": "ARLEN0",
            "wire": "axi1_arlen",
            "to_port": "axi4_if"
          },
          {
            "from_port": "ARSIZE0",
            "wire": "axi1_arsize",
            "to_port": "axi4_if"
          },
          {
            "from_port": "ARVALID0",
            "wire": "axi1_arvalid",
            "to_port": "axi4_if"
          }
        ],
        "B": [
          {
            "from_port": "BRESP0",
            "wire": "axi1_bresp",
            "to_port": "axi4_if"
          },
          {
            "from_port": "BVALID0",
            "wire": "axi1_bvalid",
            "to_port": "axi4_if"
          }
        ]
      }
    },
    {
      "id": "apb_master_to_dma",
      "type": "apb_bus",
      "label": "APB Master UVC \u2192 DMA",
      "description": "APB master UVC drives DMA APB slave interface for register access",
      "from_instance": "u_apb_master",
      "to_instance": "u_dma_axi64",
      "channel_signals": {
        "APB": [
          {
            "from_port": "apb_if",
            "wire": "apb_psel",
            "to_port": "psel"
          },
          {
            "from_port": "apb_if",
            "wire": "apb_penable",
            "to_port": "penable"
          },
          {
            "from_port": "apb_if",
            "wire": "apb_paddr",
            "to_port": "paddr"
          },
          {
            "from_port": "apb_if",
            "wire": "apb_pwrite",
            "to_port": "pwrite"
          },
          {
            "from_port": "apb_if",
            "wire": "apb_pwdata",
            "to_port": "pwdata"
          }
        ]
      }
    },
    {
      "id": "sideband_to_dma",
      "type": "sideband",
      "label": "Sideband \u2192 DMA",
      "description": "Sideband signals: peripheral requests, scan, idle, interrupt",
      "from_instance": "u_sideband",
      "to_instance": "u_dma_axi64",
      "channel_signals": {
        "SIDEBAND": [
          {
            "from_port": "periph_tx_req",
            "wire": "periph_tx_req",
            "to_port": "periph_tx_req"
          },
          {
            "from_port": "periph_rx_req",
            "wire": "periph_rx_req",
            "to_port": "periph_rx_req"
          },
          {
            "from_port": "scan_en",
            "wire": "scan_en",
            "to_port": "scan_en"
          }
        ]
      }
    },
    {
      "id": "dma_to_sideband",
      "type": "sideband",
      "label": "DMA \u2192 Sideband",
      "description": "DMA output sideband signals: clears, idle, interrupt",
      "from_instance": "u_dma_axi64",
      "to_instance": "u_sideband",
      "channel_signals": {
        "SIDEBAND": [
          {
            "from_port": "periph_tx_clr",
            "wire": "periph_tx_clr",
            "to_port": "periph_tx_clr"
          },
          {
            "from_port": "periph_rx_clr",
            "wire": "periph_rx_clr",
            "to_port": "periph_rx_clr"
          },
          {
            "from_port": "idle",
            "wire": "idle",
            "to_port": "idle"
          },
          {
            "from_port": "INT",
            "wire": "INT",
            "to_port": "INT"
          }
        ]
      }
    }
  ],
  "groups": [
    {
      "name": "dut_group",
      "label": "DMA AXI 64 (DUT)",
      "description": "Device Under Test \u2014 DMA AXI 64-bit controller",
      "color": "#FF9800",
      "padding": 1.0,
      "members": [
        "u_dma_axi64"
      ]
    },
    {
      "name": "axi_uvc_group",
      "label": "AXI4 Slave UVCs",
      "description": "Two AXI4 slave UVC instances for DMA master port verification",
      "color": "#00897B",
      "padding": 1.0,
      "members": [
        "u_axi4_slave0",
        "u_axi4_slave1"
      ]
    },
    {
      "name": "apb_uvc_group",
      "label": "APB Master UVC",
      "description": "APB master UVC for DMA register access verification",
      "color": "#1565C0",
      "padding": 1.0,
      "members": [
        "u_apb_master"
      ]
    }
  ]
}
