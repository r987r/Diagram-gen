{
  "design_name": "axi4_wide_interconnect",
  "version": "2.0",
  "description": "Scalable multi-master, multi-slave AXI4 interconnect design. Three AXI4 masters (CPU, DMA, GPU) connect through an AXI4 crossbar/interconnect to four AXI4 slaves (SRAM, DDR Controller, UART, SPI). The interconnect widens the ID field from 4 bits to 6 bits by appending a 2-bit source identifier on the master-side output ports.",
  "includes": [
    "blocks/axi4_crossbar_subsystem.json"
  ],
  "parameters": {
    "DATA_WIDTH": 64,
    "ADDR_WIDTH": 32,
    "ID_WIDTH": 4,
    "ID_WIDTH_OUT": 6,
    "STRB_WIDTH": 8,
    "NUM_MASTERS": 3,
    "NUM_SLAVES": 4
  },
  "testbench": {
    "module_name": "tb_top",
    "description": "Top-level testbench. Declares clk and rst_n and drives them to all DUT instances.",
    "global_signals": [
      {
        "name": "clk",
        "width": 1,
        "type": "reg",
        "description": "System clock. Connects to the BOTTOM port of every instance cube.",
        "render": {
          "face": "bottom",
          "color": "#00E676"
        }
      },
      {
        "name": "rst_n",
        "width": 1,
        "type": "reg",
        "description": "Active-low synchronous reset. Connects to the TOP port of every instance cube.",
        "render": {
          "face": "top",
          "color": "#FF5252"
        }
      }
    ]
  },
  "modules": {},
  "instances": [],
  "connections": [
    {
      "id": "clk_fanout",
      "type": "clock",
      "description": "System clock from testbench to all 8 instances (enters at BOTTOM of each cube)",
      "from": {
        "instance": "tb_top",
        "port": "clk"
      },
      "to": [
        {
          "instance": "u_cpu",
          "port": "clk"
        },
        {
          "instance": "u_dma",
          "port": "clk"
        },
        {
          "instance": "u_gpu",
          "port": "clk"
        },
        {
          "instance": "u_xbar",
          "port": "clk"
        },
        {
          "instance": "u_sram",
          "port": "clk"
        },
        {
          "instance": "u_ddr",
          "port": "clk"
        },
        {
          "instance": "u_uart",
          "port": "clk"
        },
        {
          "instance": "u_spi",
          "port": "clk"
        }
      ]
    },
    {
      "id": "rst_fanout",
      "type": "reset",
      "description": "Active-low reset from testbench to all 8 instances (enters at TOP of each cube)",
      "from": {
        "instance": "tb_top",
        "port": "rst_n"
      },
      "to": [
        {
          "instance": "u_cpu",
          "port": "rst_n"
        },
        {
          "instance": "u_dma",
          "port": "rst_n"
        },
        {
          "instance": "u_gpu",
          "port": "rst_n"
        },
        {
          "instance": "u_xbar",
          "port": "rst_n"
        },
        {
          "instance": "u_sram",
          "port": "rst_n"
        },
        {
          "instance": "u_ddr",
          "port": "rst_n"
        },
        {
          "instance": "u_uart",
          "port": "rst_n"
        },
        {
          "instance": "u_spi",
          "port": "rst_n"
        }
      ]
    }
  ]
}
