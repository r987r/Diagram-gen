      "position": {
        "x": -16,
        "y": -4,
        "z": 0
      }
    },
    {
      "instance_name": "u_xbar",
      "module": "axi4_interconnect",
      "description": "AXI4 crossbar interconnect \u2013 3-to-4 address-decoded switch fabric",
      "position": {
        "x": 0,
        "y": 0,
        "z": 0
      }
    },
    {
      "instance_name": "u_sram",
      "module": "axi4_slave_sram",
