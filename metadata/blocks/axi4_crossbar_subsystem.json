  "description": "AXI4 crossbar subsystem: 3 masters \u2192 interconnect \u2192 4 slaves",
  "includes": [
    "axi4_master_cpu.json",
    "axi4_master_dma.json",
    "axi4_master_gpu.json",
    "axi4_interconnect.json",
