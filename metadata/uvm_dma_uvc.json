{
  "design_name": "dma_axi4_env_view",
  "version": "3.0",
  "description": "Individual view of the DMA AXI4 Env \u2014 each per-channel agent (AW, W, B, AR, R) is expanded to show its internal sequencer, driver, and monitor. Per-channel virtual interfaces connect agents to the DUT.",
  "includes": [
    "blocks/uvm_sequencer.json",
    "blocks/uvm_driver.json",
    "blocks/uvm_monitor.json",
    "blocks/uvm_sequence.json",
    "blocks/axi4_vif.json",
    "blocks/uvm_axi4_env_common.json"
  ],
  "parameters": {
    "DATA_WIDTH": 64,
    "ADDR_WIDTH": 32,
    "ID_WIDTH": 4
  },
  "testbench": {
    "module_name": "tb_top",
    "global_signals": [
      {
        "name": "clk",
        "width": 1,
        "type": "reg",
        "description": "System clock.",
        "render": {
          "face": "bottom",
          "color": "#00E676"
        }
      },
      {
        "name": "rst_n",
        "width": 1,
        "type": "reg",
        "description": "Active-low reset.",
        "render": {
          "face": "top",
          "color": "#FF5252"
        }
      }
    ],
    "description": "Testbench for DMA AXI4 Env debug view."
  },
  "connection_types": {
    "axi4_bus": {
      "color": "#FFC107",
      "description": "AXI4 Bus"
    },
    "vif": {
      "color": "#795548",
      "description": "Virtual Interface"
    },
    "tlm": {
      "color": "#E91E63",
      "description": "TLM Analysis Port"
    }
  },
  "modules": {
    "axi4_interconnect": {
      "description": "AXI4 interconnect DUT stub",
      "render": {
        "color": "#FF9800",
        "size": {
          "w": 8,
          "h": 3,
          "d": 3
        }
      },
      "ports": [
        {
          "name": "clk",
          "direction": "input",
          "width": 1,
          "channel": "GLOBAL",
          "description": "System clock"
        },
        {
          "name": "rst_n",
          "direction": "input",
          "width": 1,
          "channel": "GLOBAL",
          "description": "Active-low reset"
        }
      ]
    },
    "uvm_read_scoreboard": {
      "description": "Read scoreboard \u2014 checks AR/R channel transactions",
      "render": {
        "color": "#F44336"
      },
      "ports": [
        {
          "name": "analysis_export",
          "direction": "input",
          "width": 1,
          "channel": "TLM",
          "description": "Receives monitor transactions"
        }
      ]
    },
    "uvm_write_scoreboard": {
      "description": "Write scoreboard \u2014 checks AW/W/B channel transactions",
      "render": {
        "color": "#E91E63"
      },
      "ports": [
        {
          "name": "analysis_export",
          "direction": "input",
          "width": 1,
          "channel": "TLM",
          "description": "Receives monitor transactions"
        }
      ]
    }
  },
