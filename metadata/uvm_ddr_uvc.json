  ],
  "groups": [
    {
      "name": "ddr_uvc",
      "label": "DDR AXI4 UVC",
      "description": "DDR AXI4 UVC \u2014 contains 5 per-channel agents",
      "color": "#00897B",
      "members": [
        "ddr_aw_agent",
        "ddr_w_agent",
        "ddr_b_agent",
        "ddr_ar_agent",
        "ddr_r_agent"
      ]
    }
  ],
  "connection_types": {
