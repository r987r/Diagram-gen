            "to_port": "analysis_export"
          }
        ]
      }
    },
    {
      "id": "dut_to_ddr_ar_agent",
      "type": "axi4_bus",
      "label": "DUT \u2192 AR",
      "description": "DUT drives AR agent via VIF",
      "from_instance": "dut_stub",
      "to_instance": "ddr_ar_agent",
      "channel_signals": {
        "VIF": [
          {
            "from_port": "ddr_ar",
            "wire": "vif_handle",
            "to_port": "vif"
          }
        ]
      }
    },
    {
      "id": "read_seq_to_ddr_ar_agent",
      "type": "axi4_bus",
      "label": "seq \u2192 AR",
      "description": "Read sequence drives AR agent",
      "from_instance": "read_seq",
      "to_instance": "ddr_ar_agent",
      "channel_signals": {
        "TLM": [
          {
            "from_port": "seq_item_port",
            "wire": "seq_item_port",
            "to_port": "seq_item_export"
          }
        ]
      }
    },
    {
      "id": "ddr_ar_agent_to_read_sb",
      "type": "axi4_bus",
      "label": "AR \u2192 SB",
      "description": "AR monitor to read scoreboard",
      "from_instance": "ddr_ar_agent",
      "to_instance": "read_sb",
      "channel_signals": {
        "TLM": [
          {
            "from_port": "analysis_port",
            "wire": "analysis_write",
            "to_port": "analysis_export"
          }
        ]
      }
    },
    {
      "id": "dut_to_ddr_r_agent",
      "type": "axi4_bus",
      "label": "DUT \u2192 R",
      "description": "DUT drives R agent via VIF",
      "from_instance": "dut_stub",
      "to_instance": "ddr_r_agent",
      "channel_signals": {
        "VIF": [
          {
            "from_port": "ddr_r",
            "wire": "vif_handle",
            "to_port": "vif"
          }
        ]
      }
    },
    {
      "id": "read_seq_to_ddr_r_agent",
      "type": "axi4_bus",
      "label": "seq \u2192 R",
      "description": "Read sequence drives R agent",
      "from_instance": "read_seq",
