{
  "design_name": "uvc_apb",
  "version": "1.0",
  "description": "APB UVC \u2014 per-channel agents (APB) with sequencers, drivers, monitors, and virtual interfaces.",
  "includes": [
    "blocks/uvm_sequencer.json",
    "blocks/uvm_driver.json",
    "blocks/uvm_monitor.json",
    "blocks/uvm_sequence.json",
    "blocks/uvm_scoreboard.json",
    "blocks/apb_vif.json",
    "blocks/apb_dut_stub.json"
  ],
  "parameters": {},
  "testbench": {
    "module_name": "tb_top",
    "description": "Testbench for APB UVC.",
    "global_signals": [
      {
        "name": "pclk",
        "width": 1,
        "type": "reg",
        "description": "APB clock.",
        "render": {
          "face": "bottom",
          "color": "#00E676"
        }
      },
      {
        "name": "preset_n",
        "width": 1,
        "type": "reg",
        "description": "APB reset.",
        "render": {
          "face": "top",
          "color": "#FF5252"
        }
      }
    ]
  },
  "connection_types": {
    "apb_bus": {
      "color": "#4CAF50",
      "description": "APB Bus"
    },
    "vif": {
      "color": "#795548",
      "description": "Virtual Interface"
    },
    "tlm": {
      "color": "#E91E63",
      "description": "TLM Analysis Port"
    }
  },
  "modules": {},
  "instances": [
    {
      "instance_name": "apb_sqr",
      "module": "uvm_sequencer",
      "position": {
        "x": -5,
        "y": 6,
        "z": 0
      }
    },
    {
      "instance_name": "apb_drv",
      "module": "uvm_driver",
      "position": {
        "x": -1,
        "y": 6,
        "z": 0
      }
    },
    {
      "instance_name": "apb_mon",
      "module": "uvm_monitor",
      "position": {
        "x": 3,
        "y": 6,
        "z": 0
      }
    },
    {
      "instance_name": "apb_vif",
      "module": "apb_vif",
      "position": {
        "x": -1,
        "y": 2,
        "z": 0
      }
    },
    {
      "instance_name": "dut_stub",
      "module": "apb_dut_stub",
      "position": {
        "x": 0,
        "y": -6,
        "z": 0
      }
    },
    {
      "instance_name": "seq",
      "module": "uvm_sequence",
      "position": {
        "x": 7,
        "y": 6,
        "z": 0
      }
    },
    {
      "instance_name": "sb",
      "module": "uvm_scoreboard",
      "position": {
        "x": 7,
        "y": 2,
        "z": 0
      }
    }
  ],
  "connections": [
    {
      "id": "clk_fanout",
      "type": "clock",
      "description": "APB clock to all VIFs and DUT",
      "from": {
        "instance": "tb_top",
        "port": "pclk"
      },
      "to": [
        {
          "instance": "apb_vif",
          "port": "pclk"
        },
        {
          "instance": "dut_stub",
          "port": "pclk"
        }
      ]
    },
    {
      "id": "rst_fanout",
      "type": "reset",
      "description": "APB reset to all VIFs and DUT",
      "from": {
        "instance": "tb_top",
        "port": "preset_n"
      },
      "to": [
        {
          "instance": "apb_vif",
          "port": "preset_n"
        },
        {
          "instance": "dut_stub",
          "port": "preset_n"
        }
      ]
    },
    {
      "id": "apb_sqr_to_drv",
      "type": "tlm",
      "label": "APB sqr\u2192drv",
      "description": "APB sequencer to driver",
      "from_instance": "apb_sqr",
      "to_instance": "apb_drv",
      "channel_signals": {
        "TLM": [
          {
            "from_port": "seq_item_port",
            "wire": "apb_seq_item",
            "to_port": "seq_item_port"
          }
        ]
      }
    },
    {
      "id": "apb_drv_to_vif",
      "type": "vif",
      "label": "APB drv\u2192vif",
      "description": "APB driver to virtual interface",
      "from_instance": "apb_drv",
      "to_instance": "apb_vif",
      "channel_signals": {
        "VIF": [
          {
            "from_port": "vif",
            "wire": "apb_drv_vif",
            "to_port": "driver_mp"
          }
        ]
      }
    },
    {
      "id": "apb_mon_to_vif",
      "type": "vif",
      "label": "APB mon\u2192vif",
      "description": "APB monitor to virtual interface",
      "from_instance": "apb_mon",
      "to_instance": "apb_vif",
      "channel_signals": {
        "VIF": [
          {
            "from_port": "vif",
            "wire": "apb_mon_vif",
            "to_port": "monitor_mp"
          }
        ]
      }
    },
    {
      "id": "apb_mon_to_sb",
      "type": "tlm",
      "label": "APB mon\u2192SB",
      "description": "APB monitor analysis to APB Scoreboard",
      "from_instance": "apb_mon",
      "to_instance": "sb",
      "channel_signals": {
        "TLM": [
          {
            "from_port": "analysis_port",
            "wire": "apb_mon_ap",
            "to_port": "analysis_export"
          }
        ]
      }
    },
    {
      "id": "seq_to_apb",
      "type": "tlm",
      "label": "APB seq\u2192SQR",
      "description": "Sequence generates APB channel transactions",
      "from_instance": "seq",
      "to_instance": "apb_sqr",
      "channel_signals": {
        "TLM": [
          {
            "from_port": "seq_item_port",
            "wire": "seq_out",
            "to_port": "seq_item_port"
          }
        ]
      }
    },
    {
      "id": "apb_vif_to_dut",
      "type": "apb_bus",
      "label": "APB vif \u2192 DUT",
      "description": "APB virtual interface connects to DUT",
      "from_instance": "apb_vif",
      "to_instance": "dut_stub",
      "channel_signals": {
        "VIF": [
          {
            "from_port": "dut_mp",
            "wire": "vif_handle",
            "to_port": "apb"
          }
        ]
      }
    }
  ],
  "groups": [
    {
      "name": "apb_agent",
      "label": "APB Agent",
      "description": "APB APB channel agent (sequencer + driver + monitor + VIF)",
      "color": "#42A5F5",
      "padding": 0.8,
      "members": [
        "apb_sqr",
        "apb_drv",
        "apb_mon",
        "apb_vif"
      ]
    },
    {
      "name": "apb_env",
      "label": "APB Env",
      "description": "APB Env \u2014 1 per-channel agents (APB), sequences, and scoreboards.",
      "color": "#1B5E20",
      "padding": 1.5,
      "members": [
        "apb_sqr",
        "apb_drv",
        "apb_mon",
        "apb_vif",
        "seq",
        "sb"
      ]
    }
  ]
}
