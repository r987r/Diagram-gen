{
  "design_name": "uvm_axi4_super",
  "version": "1.0.0",
  "description": "Super example: UVM verification environment wrapping the AXI4 wide interconnect. Each RTL master/slave is replaced by a UVC agent (BFM) that drives and monitors the interface. The AXI4 crossbar remains as the DUT, while UVM agents, monitors and scoreboards verify correctness.",
  "parameters": {
    "DATA_WIDTH": 64,
    "ADDR_WIDTH": 32,
    "ID_WIDTH": 4,
    "ID_WIDTH_OUT": 6,
    "STRB_WIDTH": 8,
    "NUM_MASTERS": 3,
    "NUM_SLAVES": 4
  },
  "testbench": {
    "module_name": "tb_top",
    "description": "Top-level testbench. Drives clk/rst and connects virtual interfaces between the DUT interconnect and UVC agents.",
    "global_signals": [
      {
        "name": "clk",
        "width": 1,
        "type": "reg",
        "description": "System clock.",
        "render": {
          "face": "bottom",
          "color": "#00E676"
        }
      },
      {
        "name": "rst_n",
        "width": 1,
        "type": "reg",
        "description": "Active-low synchronous reset.",
        "render": {
          "face": "top",
          "color": "#FF5252"
        }
      }
    ]
  },
  "modules": {
    "uvm_env": {
      "description": "Top-level UVM environment. Contains all master/slave agents, the scoreboard and the interconnect DUT.",
      "render": {
        "color": "#3F51B5"
      },
      "ports": [
        {
          "name": "clk",
          "direction": "input",
          "width": 1,
          "channel": "GLOBAL"
        },
        {
          "name": "rst_n",
          "direction": "input",
          "width": 1,
          "channel": "GLOBAL"
        }
      ]
    },
    "axi4_master_uvc": {
      "description": "AXI4 master UVC agent (BFM). Replaces the RTL master. Contains sequencer, driver and monitor for generating and observing AXI4 master transactions.",
      "render": {
        "color": "#2196F3"
      },
      "ports": [
        {
          "name": "clk",
          "direction": "input",
          "width": 1,
          "channel": "GLOBAL"
        },
        {
          "name": "rst_n",
          "direction": "input",
          "width": 1,
          "channel": "GLOBAL"
        },
        {
          "name": "analysis_port",
          "direction": "output",
          "width": 1,
          "channel": "TLM",
          "description": "Monitor analysis port"
        },
        {
          "name": "vif",
          "direction": "output",
          "width": 1,
          "channel": "VIF",
          "description": "Virtual interface to DUT"
        }
      ]
    },
    "axi4_interconnect": {
      "description": "AXI4 crossbar / interconnect (DUT). Routes transactions from master ports to slave ports based on address decoding. This is the real RTL design under verification.",
      "render": {
        "color": "#FF9800"
      },
      "ports": [
        {
          "name": "clk",
          "direction": "input",
          "width": 1,
          "channel": "GLOBAL"
        },
        {
          "name": "rst_n",
          "direction": "input",
          "width": 1,
          "channel": "GLOBAL"
        },
        {
          "name": "s0_awid",
          "direction": "input",
          "width": 4,
          "channel": "AW",
          "side": "slave",
          "description": "Master port 0 write address ID"
        },
        {
          "name": "s0_awaddr",
          "direction": "input",
          "width": 32,
          "channel": "AW",
          "side": "slave"
        },
        {
          "name": "s0_awvalid",
          "direction": "input",
          "width": 1,
          "channel": "AW",
          "side": "slave"
        },
        {
          "name": "s0_awready",
          "direction": "output",
          "width": 1,
          "channel": "AW",
          "side": "slave"
        },
        {
          "name": "m0_awid",
          "direction": "output",
          "width": 6,
          "channel": "AW",
          "side": "master"
        },
        {
          "name": "m0_awaddr",
          "direction": "output",
          "width": 32,
          "channel": "AW",
          "side": "master"
        },
        {
          "name": "m0_awvalid",
          "direction": "output",
          "width": 1,
          "channel": "AW",
          "side": "master"
        },
        {
          "name": "m0_awready",
          "direction": "input",
          "width": 1,
          "channel": "AW",
          "side": "master"
        }
      ]
    },
    "axi4_slave_uvc": {
      "description": "AXI4 slave UVC agent (BFM). Replaces the RTL slave. Contains responder driver and monitor for responding to and observing AXI4 slave transactions.",
      "render": {
        "color": "#4CAF50"
      },
      "ports": [
        {
          "name": "clk",
          "direction": "input",
          "width": 1,
          "channel": "GLOBAL"
        },
        {
          "name": "rst_n",
          "direction": "input",
          "width": 1,
          "channel": "GLOBAL"
        },
        {
          "name": "analysis_port",
          "direction": "output",
          "width": 1,
          "channel": "TLM",
          "description": "Monitor analysis port"
        },
        {
          "name": "vif",
          "direction": "output",
          "width": 1,
          "channel": "VIF",
          "description": "Virtual interface to DUT"
        }
      ]
    },
    "uvm_scoreboard": {
      "description": "UVM scoreboard. Receives transactions from all master and slave UVC monitors via TLM analysis FIFOs and checks end-to-end data integrity across the interconnect.",
      "render": {
        "color": "#F44336"
      },
      "ports": [
        {
          "name": "clk",
          "direction": "input",
          "width": 1,
          "channel": "GLOBAL"
        },
        {
          "name": "rst_n",
          "direction": "input",
          "width": 1,
          "channel": "GLOBAL"
        },
        {
          "name": "mst_analysis_export",
          "direction": "input",
          "width": 1,
          "channel": "TLM",
          "description": "Master-side analysis exports"
        },
        {
          "name": "slv_analysis_export",
          "direction": "input",
          "width": 1,
          "channel": "TLM",
          "description": "Slave-side analysis exports"
        }
      ]
    },
    "tlm_analysis_fifo": {
      "description": "UVM TLM analysis FIFO. Buffers transactions between UVC monitor analysis ports and the scoreboard.",
      "render": {
        "color": "#607D8B"
      },
      "ports": [
        {
          "name": "analysis_imp",
          "direction": "input",
          "width": 1,
          "channel": "TLM"
        },
        {
          "name": "blocking_get_export",
          "direction": "output",
          "width": 1,
          "channel": "TLM"
        }
      ]
    }
  },
